-- Application --
[F3 - Application Layer] lasts 3 days
[F3 - Application Layer] starts at [F2 - Domain Layer]'s end

-- Infrastructure --
[F4 - OpenAI Adapter] lasts 2 days
[F4 - OpenAI Adapter] starts at [F3 - Application Layer]'s end

[F5 - Redis Cache] lasts 2 days
[F5 - Redis Cache] starts at [F4 - OpenAI Adapter]'s end

-- API --
[F6 - API Layer] lasts 2 days
[F6 - API Layer] starts at [F5 - Redis Cache]'s end

-- Quality --
[F7 - Quality Gate] lasts 2 days
[F7 - Quality Gate] starts at [F6 - API Layer]'s end

-- Testing --
[F8 - Testing] lasts 3 days
[F8 - Testing] starts at [F7 - Quality Gate]'s end

-- Deploy --
[F9 - Docs & Deploy] lasts 1 days
[F9 - Docs & Deploy] starts at [F8 - Testing]'s end

@endgantt
